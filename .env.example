# Bitrefill — read only by the Vite dev proxy / Netlify edge function, never shipped to the bundle
BITREFILL_API_KEY=

# Uniswap Trading API key — register free at https://hub.uniswap.org
# Server-side only (same-origin proxy injects it): their gateway blocks CORS for non-localhost origins
UNISWAP_API_KEY=

# WalletConnect Cloud project id (required by RainbowKit) — create free at https://cloud.reown.com
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: Alchemy for token discovery (free tier) — falls back to curated list + multicall if empty
VITE_ALCHEMY_API_KEY=

# Optional demo mode: set to "balance" to pay invoices from the Bitrefill test
# account balance (never charged) — full flow without any on-chain transactions
VITE_DEMO_PAYMENT=

# Optional: Sentry DSN for error monitoring — empty disables it (no-op).
# A DSN is an ingest endpoint, not a secret. Use Sentry's free tier or a
# self-hosted GlitchTip (same SDK). Errors only; no tracing/replay.
VITE_SENTRY_DSN=

# Optional: Sentry DSN for the Netlify edge proxies (Deno, server-side). Reports
# upstream 5xx / thrown errors. Falls back to VITE_SENTRY_DSN if unset. Set in
# Netlify env vars for prod; loaded lazily so empty = logs only.
SENTRY_DSN=
